# =============================================================================
# SECURITY — never commit credentials
# =============================================================================
gcp-key.json
*.json.key
*credentials*.json
.env
secrets/

# =============================================================================
# RESULTS & CACHES — all live in GCS and persistent volume, not in the repo
# =============================================================================

# Stage caches (model-level resumption state)
stage_cache/
stage_cache_ablation/
stage_cache_prod*/

# Data caches (downloaded parquet files)
data_cache/
data_cache_production/

# Local result outputs
results/
baseline_results.*
ablation_results.*

# =============================================================================
# LOGS — operational, not scientific artefacts
# =============================================================================
logs/
*.log
nohup.out

# =============================================================================
# JUPYTER CHECKPOINTS
# =============================================================================
.ipynb_checkpoints/
**/.ipynb_checkpoints/
scripts/.ipynb_checkpoints/

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.Python

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
venv/
env/
.venv/
.env/

# =============================================================================
# TEMPORARY FILES
# =============================================================================
/tmp/
*.tmp
*.temp
*.parquet.tmp

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# MODEL WEIGHTS — large files, live in GCS
# =============================================================================
*.pt
*.pkl
*.h5
*.onnx

# =============================================================================
# WRITE PROBES
# =============================================================================
.write_probe

